{
   "compilerOptions": {
        "target": "es2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "noResolve": false,
        "noImplicitAny": false,
        "sourceMap": true,
        "preserveConstEnums":true,
        "lib": [
            "dom",
            "es2020"
        ],
        "rootDir": "Scripts",
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "types": ["react"]
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}